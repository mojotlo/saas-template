# Database (Neon)
# Get these from your Neon project dashboard → Connection Details
# DATABASE_URL uses the pooled connection (for app queries)
# DIRECT_DATABASE_URL uses the unpooled connection (for migrations)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require&pgbouncer=true
DIRECT_DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Node environment
NODE_ENV=development
