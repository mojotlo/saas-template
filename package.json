{
  "name": "project-name",
  "version": "0.1.0",
  "description": "",
  "scripts": {
    "dev": "echo 'No dev server configured yet'",
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "vitest run && npx tsx scripts/summarize-tests.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage && npx tsx scripts/summarize-tests.ts",
    "test:integration": "vitest run --config vitest.config.integration.ts",
    "test:e2e": "playwright test",
    "test:summary": "npx tsx scripts/summarize-tests.ts",
    "test:all": "npm test && npm run test:integration && npm run test:e2e",
    "worktree:new": "bash scripts/new-worktree.sh",
    "worktree:cleanup": "bash scripts/cleanup-worktree.sh",
    "test:check-integrity": "bash scripts/check-test-modifications.sh"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "prisma": "^5.0.0"
  }
}
